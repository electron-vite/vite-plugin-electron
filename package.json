{
  "name": "vite-plugin-electron",
  "version": "1.0.4",
  "description": "Electron 🔗 Vite",
  "keywords": [
    "electron",
    "plugin",
    "renderer",
    "vite"
  ],
  "license": "MIT",
  "author": "Leo Wang(草鞋没号) <308487730@qq.com>",
  "maintainers": [
    "subframe7536"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-vite/vite-plugin-electron.git"
  },
  "files": [
    "dist",
    "electron-env.d.ts",
    "plugin.d.ts",
    "simple.d.ts",
    "multi-env.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./multi-env": {
      "import": "./dist/multi-env.mjs",
      "require": "./dist/multi-env.cjs"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./simple": {
      "import": "./dist/simple.mjs",
      "require": "./dist/simple.cjs"
    },
    "./package.json": "./package.json",
    "./electron-env": {
      "types": "./electron-env.d.ts"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types": "tsc",
    "test": "vitest run",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "qa": "pnpm run lint && pnpm run format && pnpm run types && pnpm run test",
    "play": "pnpm --dir playground/flat dev",
    "play:multi-env": "pnpm --dir playground/multi-env dev",
    "play:simple": "pnpm --dir playground/simple dev",
    "play:worker": "pnpm --dir playground/worker dev",
    "play:build": "pnpm --dir playground/flat build",
    "play:build:multi-env": "pnpm --dir playground/multi-env build",
    "play:build:simple": "pnpm --dir playground/simple build",
    "play:build:worker": "pnpm --dir playground/worker build",
    "release": "pnpm run qa && pnpm run prepublishOnly && bumpp --all",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "local-pkg": "^1.2.1"
  },
  "devDependencies": {
    "@subf/config": "^0.2.1",
    "@types/node": "^24.12.4",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "vite-plugin-electron-renderer": "*"
  },
  "peerDependenciesMeta": {
    "vite-plugin-electron-renderer": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.4"
}
