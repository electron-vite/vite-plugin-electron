{
  "name": "vite-plugin-electron",
  "version": "1.0.0-beta.2",
  "description": "Electron 🔗 Vite",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./simple": {
      "import": "./dist/simple.mjs",
      "require": "./dist/simple.cjs"
    },
    "./package.json": "./package.json",
    "./electron-env": {
      "types": "./electron-env.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-vite/vite-plugin-electron.git"
  },
  "author": "Leo Wang(草鞋没号) <308487730@qq.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types": "tsc",
    "test": "vitest run",
    "release": "pnpm run prepublishOnly && bumpp --all",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "peerDependencies": {
    "vite-plugin-electron-renderer": "*"
  },
  "peerDependenciesMeta": {
    "vite-plugin-electron-renderer": {
      "optional": true
    }
  },
  "dependencies": {
    "local-pkg": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "local-pkg": "^1.1.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "electron-env.d.ts",
    "plugin.d.ts",
    "simple.d.ts"
  ],
  "keywords": [
    "vite",
    "plugin",
    "electron",
    "renderer"
  ]
}