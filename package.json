{
  "name": "vite-plugin-electron",
  "version": "1.0.0",
  "description": "Electron 🔗 Vite",
  "keywords": [
    "electron",
    "plugin",
    "renderer",
    "vite"
  ],
  "license": "MIT",
  "author": "Leo Wang(草鞋没号) <308487730@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-vite/vite-plugin-electron.git"
  },
  "files": [
    "dist",
    "electron-env.d.ts",
    "plugin.d.ts",
    "simple.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    },
    "./simple": {
      "types": "./dist/simple.d.ts",
      "import": "./dist/simple.js",
      "require": "./dist/simple.cjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test",
    "prepublishOnly": "vp pack && vp test",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.11",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "vite-plugin-electron-renderer": "*"
  },
  "peerDependenciesMeta": {
    "vite-plugin-electron-renderer": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.32.1"
}
