{
  "name": "vite-plugin-electron",
  "version": "1.0.0-beta.4",
  "description": "Electron 🔗 Vite",
  "keywords": [
    "electron",
    "plugin",
    "renderer",
    "vite"
  ],
  "license": "MIT",
  "author": "Leo Wang(草鞋没号) <308487730@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-vite/vite-plugin-electron.git"
  },
  "files": [
    "dist",
    "electron-env.d.ts",
    "plugin.d.ts",
    "simple.d.ts",
    "multi-env.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./multi-env": {
      "import": "./dist/multi-env.mjs",
      "require": "./dist/multi-env.cjs"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./simple": {
      "import": "./dist/simple.mjs",
      "require": "./dist/simple.cjs"
    },
    "./package.json": "./package.json",
    "./electron-env": {
      "types": "./electron-env.d.ts"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "types": "tsc",
    "test": "vitest run",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "play": "pnpm --dir playground/flat dev",
    "play:env": "pnpm --dir playground/environments dev",
    "play:simple": "pnpm --dir playground/simple dev",
    "play:build": "pnpm --dir playground/flat build",
    "play:build:env": "pnpm --dir playground/environments build",
    "play:build:simple": "pnpm --dir playground/simple build",
    "release": "pnpm run lint && pnpm run format && pnpm run prepublishOnly && bumpp --all",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "local-pkg": "^1.1.2"
  },
  "devDependencies": {
    "@subf/config": "^0.2.1",
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "vite-plugin-electron-renderer": "*"
  },
  "peerDependenciesMeta": {
    "vite-plugin-electron-renderer": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.26.1"
}
