{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "allowJs": true,
    "declaration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "types",
    "emitDeclarationOnly": true,
    "types": ["node"]
  },
  "include": ["src", "electron-env.d.ts"]
}
